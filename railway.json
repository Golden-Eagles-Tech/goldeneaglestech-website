{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "envsubst '$PORT' < /app/nginx.conf > /tmp/nginx-runtime.conf && nginx -c /tmp/nginx-runtime.conf -g 'daemon off;'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
